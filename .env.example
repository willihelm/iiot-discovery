## ---- Ports (host) ----
MQTT_PORT=1883
INFLUX_PORT=8086
GRAFANA_PORT=3000

## ---- MQTT ----
MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC_PREFIX=uns/v1/acme/berlin/packaging

## ---- InfluxDB 2 (auto-init) ----
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminadminadmin
INFLUXDB_ORG=acme
INFLUXDB_BUCKET=iiot
# You can generate a new token later; for demo we set a deterministic one.
INFLUXDB_ADMIN_TOKEN=iiot-demo-token-change-me
INFLUXDB_RETENTION=30d

## ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

## ---- Ingest ----
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=iiot-demo-token-change-me
INFLUX_MEASUREMENT=telemetry

## ---- Simulation ----
PUBLISH_INTERVAL_MS=1000
